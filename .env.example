# Evolution API Configuration
EVOLUTION_API_URL=http://your-evolution-api-host:8080
EVOLUTION_API_KEY=your_global_or_instance_apikey
EVOLUTION_INSTANCE=your_instance_name

# Target Contact Details
# Example number: 5511999999999 (Country code + Area code + Number)
RECIPIENT_NUMBER=5511999999999
MESSAGE_TEXT=Olá! Esta é uma mensagem diária programada automaticamente.

# Scheduling Configuration
# Format: HH:MM (24-hour format)
SCHEDULED_TIME=10:00
TIMEZONE=America/Sao_Paulo
